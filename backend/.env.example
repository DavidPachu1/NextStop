# ── Anthropic ───────────────────────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily Search (para búsquedas web en tiempo real) ───────────────────────
# Obtén tu clave GRATIS en: https://tavily.com  (1000 búsquedas/mes gratis)
# Si no la configuras, los agentes funcionarán sin búsquedas en tiempo real.
TAVILY_API_KEY=tvly-...

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS (URL del frontend) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
